{
  "name": "openapi-projector",
  "version": "0.1.1",
  "description": "Review-first OpenAPI DTO/API candidate generator for frontend projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/aqwsde321/openapi-projector.git"
  },
  "bugs": {
    "url": "https://github.com/aqwsde321/openapi-projector/issues"
  },
  "homepage": "https://github.com/aqwsde321/openapi-projector#readme",
  "packageManager": "pnpm@10.28.2",
  "type": "module",
  "bin": {
    "openapi-projector": "./bin/openapi-tool.mjs",
    "openapi-tool": "./bin/openapi-tool.mjs"
  },
  "files": [
    "bin",
    "config",
    "docs",
    "src",
    "templates",
    "README.md"
  ],
  "keywords": [
    "openapi",
    "typescript",
    "frontend",
    "dto",
    "api-client"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "help": "node ./bin/openapi-tool.mjs help",
    "init": "node ./bin/openapi-tool.mjs init",
    "openapi:help": "node ./bin/openapi-tool.mjs help",
    "openapi:init": "node ./bin/openapi-tool.mjs init",
    "openapi:download": "node ./bin/openapi-tool.mjs download",
    "openapi:catalog": "node ./bin/openapi-tool.mjs catalog",
    "openapi:generate": "node ./bin/openapi-tool.mjs generate",
    "openapi:rules": "node ./bin/openapi-tool.mjs rules",
    "openapi:project": "node ./bin/openapi-tool.mjs project",
    "openapi:refresh": "node ./bin/openapi-tool.mjs refresh",
    "openapi:doctor": "node ./bin/openapi-tool.mjs doctor",
    "openapi:prepare": "node ./bin/openapi-tool.mjs prepare",
    "test": "node --test"
  },
  "dependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
