{
  // 이 파일을 .openapi-tool.local.jsonc 로 복사해서 사용합니다.
  // help 를 제외한 모든 명령은 projectRoot 가 비어 있으면 실행되지 않습니다.
  "projectRoot": "",
  "initDefaults": {
    // init 시 대상 프로젝트 openapi/config/project.jsonc 의 기본값으로 채웁니다.
    // 여기에 Swagger UI 주소가 아니라 OpenAPI JSON 요청 URL(예: /v3/api-docs)을 적습니다.
    "sourceUrl": ""
  }
}
